{
  "name": "wabag-bureau-ordre",
  "version": "1.0.3",
  "description": "WABAG Bureau d'Ordre — desktop client",
  "author": "VA Tech WABAG Tunisie",
  "license": "UNLICENSED",
  "repository": "github:ElyesD1/wabag-bureau-ordre",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev:web": "vite",
    "dev": "concurrently -k \"vite\" \"wait-on tcp:127.0.0.1:5173 && cross-env ELECTRON_DEV=1 electron electron/main.cjs\"",
    "build": "vite build",
    "preview": "vite preview --port 4173",
    "gen-config": "node scripts/gen-server-config.mjs",
    "package:win": "npm run build && npm run gen-config && electron-builder --win --publish never",
    "package:mac": "npm run build && npm run gen-config && electron-builder --mac --publish never"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.1",
    "@tanstack/react-query": "^5.59.16",
    "bonjour-service": "^1.4.2",
    "i18next": "^23.16.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.53.1",
    "react-i18next": "^15.1.0",
    "react-router-dom": "^6.27.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "concurrently": "^9.0.1",
    "cross-env": "^7.0.3",
    "electron": "^33.0.2",
    "electron-builder": "^25.1.8",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "wait-on": "^8.0.1"
  }
}
